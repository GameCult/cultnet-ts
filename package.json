{
  "name": "cultnet-ts",
  "version": "0.1.0",
  "description": "CultNet-style typed direct-pipe messaging and state replication for TypeScript runtimes.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "contracts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --pretty false",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js"
  },
  "keywords": [
    "messagepack",
    "networking",
    "pipes",
    "cultcache",
    "gamecult",
    "typescript"
  ],
  "author": "metacratic",
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "ajv": "^8.17.1",
    "cultcache-ts": "github:GameCult/cultcache-ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "zod": "^3.25.76"
  }
}

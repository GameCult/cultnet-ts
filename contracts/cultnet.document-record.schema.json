{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GameCult/cultnet-ts/contracts/cultnet.document-record.schema.json",
  "title": "CultNet Document Record",
  "type": "object",
  "required": [
    "schemaId",
    "recordKey",
    "storedAt",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaId": { "type": "string", "minLength": 1 },
    "recordKey": { "type": "string", "minLength": 1 },
    "storedAt": { "type": "string", "minLength": 1 },
    "payload": {},
    "sourceRuntimeId": { "type": "string", "minLength": 1 },
    "sourceAgentId": { "type": "string", "minLength": 1 },
    "sourceRole": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
